    "type": "rounded-rect",
    "backgroundColor": "theme.muted",
    "borderRadius": 8
  },
  "stem": {
    "type": "rounded-rect",
    "backgroundColor": "theme.primary",
    "borderRadius": 3
  },
  "leaf": {
    "type": "rounded-rect",
    "backgroundColor": "theme.accent",
    "borderRadius": 15
  },
  "animations": {
    "sway": {
      "duration": 2500,
      "rotationRange": [-3, 3]
    },
    "grow": {
      "duration": 4000,
      "scaleRange": [1, 1.05]
    },
    "leafPulse": {
      "duration": 1500,
      "opacityRange": [0.7, 1]
    }
  },
  "growthIndicator": {
    "type": "progress-bar",
    "width": 60,
    "height": 4,
    "borderRadius": 2,
    "backgroundColor": "theme.primary",
    "fillColor": "theme.primaryForeground",
    "fillWidth": "dynamic based on level (level/5 * 100%)"
  },
  "shadow": {
    "offset": { "x": 0, "y": 8 },
    "opacity": 0.12,
    "borderRadius": 4
  },
  "position": {
    "bottom": 120,
