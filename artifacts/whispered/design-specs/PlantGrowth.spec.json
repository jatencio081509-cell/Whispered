  "pot": {
    "type": "container",
    "gradient": ["theme.card", "theme.border"],
    "rim": {
      "height": 8,
      "backgroundColor": "theme.border",
      "borderRadius": 4
    },
    "detail": {
      "height": 2,
      "backgroundColor": "theme.border",
      "opacity": 0.3
    }
  },
