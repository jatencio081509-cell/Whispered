{
  "component": "MoodLamp",
  "description": "Mood lamp with colored glow effects showing partner's mood",
  "dimensions": {
    "base": { "width": 50, "height": 18, "borderRadius": 25 },
    "stand": { "width": 4, "height": 70, "borderRadius": 2 },
    "shade": { "width": 45, "height": 45, "borderRadius": 22 }
  },
  "colors": {
    "base": "theme.card",
    "stand": "theme.border",
    "shade": "theme.card",
    "accent": "theme.primary",
    "shadow": "rgba(0,0,0,0.15)"
  },
  "moodColors": {
    "😊": "theme.success",
    "😢": "theme.rose",
    "😡": "theme.destructive",
    "😰": "theme.accent",
    "😴": "theme.mutedForeground",
    "🥰": "theme.primary",
    "😎": "theme.tint",
    "🤔": "theme.border",
    "😆": "theme.primary",
    "😌": "theme.accent"
  },
  "gradients": {
    "base": ["theme.card", "theme.border"],
    "shade": ["theme.card", "moodColor", "theme.card"]
  },
  "animations": {
    "glow": {
      "duration": 2000,
      "opacityRange": [0.4, 0.8]
    },
    "pulse": {
      "duration": 1500,
      "scaleRange": [1, 1.1]
    }
  },
  "layers": [
    {
      "name": "Lamp Glow",
      "type": "glow-effect",
      "size": { "width": 85, "height": 85 },
      "borderRadius": 40,
      "opacity": "animated",
      "backgroundColor": "moodColor",
      "blur": 20
    },
    {
      "name": "Lamp Base",
      "type": "rounded-rect",
      "gradient": ["theme.card", "theme.border"],
      "borderRadius": 25,
      "shadow": {
        "offset": { "x": 0, "y": 2 },
        "blur": 4,
        "opacity": 0.2
      }
    },
    {
      "name": "Base Detail",
      "type": "line",
      "height": 2,
      "backgroundColor": "theme.border",
      "opacity": 0.3
    },
    {
      "name": "Lamp Stand",
      "type": "rounded-rect",
      "width": 4,
      "height": 70,
      "borderRadius": 2,
      "backgroundColor": "theme.border"
    },
    {
      "name": "Lamp Shade",
      "type": "circle",
      "width": 45,
      "height": 45,
      "borderRadius": 22,
      "gradient": ["theme.card", "moodColor", "theme.card"],
      "shadow": {
        "offset": { "x": 0, "y": 3 },
        "blur": 6,
        "opacity": 0.25
      }
    },
    {
      "name": "Light Source",
      "type": "circle",
      "size": { "width": 36, "height": 36 },
      "borderRadius": 18,
      "backgroundColor": "moodColor",
      "opacity": 0.6
    },
    {
      "name": "Mood Emoji",
      "type": "text",
      "fontSize": 20,
      "position": "center"
    },
    {
      "name": "Pull Chain",
      "type": "line",
      "width": 2,
      "height": 30,
      "borderRadius": 1,
      "backgroundColor": "theme.border",
      "position": { "right": -8, "top": 100 }
    },
    {
      "name": "Chain Handle",
      "type": "circle",
      "size": { "width": 10, "height": 10 },
      "borderRadius": 5,
      "backgroundColor": "theme.primary",
      "position": { "bottom": -6, "left": -4 }
    },
    {
      "name": "Partner Label",
      "type": "pill",
      "padding": { "horizontal": 8, "vertical": 4 },
      "borderRadius": 10,
      "backgroundColor": "theme.card",
      "items": [
        {
          "name": "Label Dot",
          "type": "circle",
          "size": { "width": 6, "height": 6 },
          "borderRadius": 3,
          "backgroundColor": "moodColor"
        }
      ],
      "position": { "bottom": -20, "left": "center" }
    }
  ],
  "positions": {
    "left": {
      "top": 60,
      "left": 30
    },
    "right": {
      "top": 60,
      "right": 30
    }
  },
  "variants": [
    {
      "name": "User Lamp",
      "showPartnerLabel": false
    },
    {
      "name": "Partner Lamp",
      "showPartnerLabel": true
    }
  ]
}
