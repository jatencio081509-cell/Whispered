{
  "component": "PetCompanion",
  "description": "Illustrated pet companion (dog/cat/fish) with idle animations",
  "variants": [
    {
      "name": "Dog",
      "dimensions": {
        "body": { "width": 80, "height": 60, "borderRadius": 40 },
        "head": { "width": 50, "height": 45, "borderRadius": 25 },
        "ear": { "width": 18, "height": 25, "borderRadius": 12 }
      },
      "parts": [
        {
          "name": "Body",
          "type": "rounded-rect",
          "gradient": ["theme.card", "theme.primary"]
        },
        {
          "name": "Head",
          "type": "circle",
          "position": { "top": -20, "left": 10 },
          "backgroundColor": "theme.card"
        },
        {
          "name": "Ear Left",
          "type": "rounded-rect",
          "position": { "top": -8, "left": 2 },
          "rotation": -20,
          "backgroundColor": "theme.accent"
        },
        {
          "name": "Ear Right",
          "type": "rounded-rect",
          "position": { "top": -8, "right": 2 },
          "rotation": 20,
          "backgroundColor": "theme.accent"
        },
        {
          "name": "Eye Left",
          "type": "circle",
          "size": 10,
          "backgroundColor": "#fff",
          "pupil": { "size": 5, "backgroundColor": "theme.text" }
        },
        {
          "name": "Eye Right",
          "type": "circle",
          "size": 10,
          "backgroundColor": "#fff",
          "pupil": { "size": 5, "backgroundColor": "theme.text" }
        },
        {
          "name": "Nose",
          "type": "rounded-rect",
          "size": { "width": 12, "height": 8 },
          "borderRadius": 6,
          "backgroundColor": "theme.text"
        },
        {
          "name": "Mouth",
          "type": "rounded-rect",
          "size": { "width": 16, "height": 4 },
          "backgroundColor": "theme.border"
        },
        {
          "name": "Tail",
          "type": "rounded-rect",
          "size": { "width": 20, "height": 8 },
          "borderRadius": 4,
          "backgroundColor": "theme.accent",
          "pivot": "left center"
        },
        {
          "name": "Legs",
          "type": "rounded-rect",
          "size": { "width": 12, "height": 20 },
          "borderRadius": 6,
          "count": 4,
          "backgroundColor": "theme.card"
        }
      ]
    },
    {
      "name": "Cat",
      "dimensions": {
        "body": { "width": 70, "height": 50, "borderRadius": 35 },
        "head": { "width": 45, "height": 40, "borderRadius": 22 },
        "ear": { "width": 14, "height": 20, "borderRadius": 8 }
      },
      "parts": [
        {
          "name": "Body",
          "type": "rounded-rect",
          "gradient": ["theme.card", "theme.primary"]
        },
        {
          "name": "Head",
          "type": "circle",
          "position": { "top": -18, "left": 8 },
          "backgroundColor": "theme.card"
        },
        {
          "name": "Ear Left",
          "type": "triangle",
          "position": { "top": -10, "left": 4 },
          "rotation": -15,
          "backgroundColor": "theme.accent"
        },
        {
          "name": "Ear Right",
          "type": "triangle",
          "position": { "top": -10, "right": 4 },
          "rotation": 15,
          "backgroundColor": "theme.accent"
        },
        {
          "name": "Eye Left",
          "type": "rounded-rect",
          "size": { "width": 12, "height": 14 },
          "borderRadius": 6,
          "backgroundColor": "#fff",
          "pupil": { "size": { "width": 4, "height": 8 }, "backgroundColor": "theme.text" }
        },
        {
          "name": "Eye Right",
          "type": "rounded-rect",
          "size": { "width": 12, "height": 14 },
          "borderRadius": 6,
          "backgroundColor": "#fff",
          "pupil": { "size": { "width": 4, "height": 8 }, "backgroundColor": "theme.text" }
        },
        {
          "name": "Nose",
          "type": "triangle",
          "size": { "width": 10, "height": 6 },
          "borderRadius": 5,
          "backgroundColor": "theme.rose"
        },
        {
          "name": "Whiskers",
          "type": "lines",
          "length": 20,
          "height": 1,
          "backgroundColor": "theme.border",
          "count": 2
        },
        {
          "name": "Tail",
          "type": "rounded-rect",
          "size": { "width": 18, "height": 6 },
          "borderRadius": 3,
          "backgroundColor": "theme.accent",
          "pivot": "left center"
        },
        {
          "name": "Legs",
          "type": "rounded-rect",
          "size": { "width": 10, "height": 16 },
          "borderRadius": 5,
          "count": 4,
          "backgroundColor": "theme.card"
        }
      ]
    },
    {
      "name": "Fish",
      "dimensions": {
        "bowl": { "width": 90, "height": 90, "borderRadius": 45 },
        "fish": { "width": 50, "height": 30, "borderRadius": 25 }
      },
      "parts": [
        {
          "name": "Fish Bowl",
          "type": "circle",
          "borderWidth": 3,
          "borderColor": "theme.border",
          "backgroundColor": "theme.card",
          "overflow": "hidden"
        },
        {
          "name": "Water",
          "type": "linear-gradient",
          "gradient": ["theme.primary", "theme.accent"],
          "fill": "100%"
        },
        {
          "name": "Fish Body",
          "type": "rounded-rect",
          "size": { "width": 50, "height": 30 },
          "borderRadius": 25,
          "backgroundColor": "theme.card"
        },
        {
          "name": "Fish Tail",
          "type": "rounded-rect",
          "size": { "width": 16, "height": 14 },
          "borderRadius": 8,
          "backgroundColor": "theme.accent",
          "pivot": "left center"
        },
        {
          "name": "Fish Eye",
          "type": "circle",
          "size": 8,
          "backgroundColor": "#fff",
          "pupil": { "size": 3, "backgroundColor": "theme.text" }
        },
        {
          "name": "Fish Mouth",
          "type": "rounded-rect",
          "size": { "width": 6, "height": 3 },
          "borderRadius": 2,
          "backgroundColor": "theme.border"
        },
        {
          "name": "Fish Fin Top",
          "type": "rounded-rect",
          "size": { "width": 12, "height": 8 },
          "borderRadius": 6,
          "backgroundColor": "theme.accent"
        },
        {
          "name": "Fish Fin Side",
          "type": "rounded-rect",
          "size": { "width": 12, "height": 8 },
          "borderRadius": 6,
          "rotation": -30,
          "backgroundColor": "theme.accent"
        },
        {
          "name": "Bubbles",
          "type": "circles",
          "sizes": [8, 5],
          "backgroundColor": "theme.primary",
          "opacity": 0.4,
          "count": 2
        }
      ]
    }
  ],
  "animations": {
    "bounce": {
      "duration": 1500,
      "yRange": [0, -8]
    },
    "tailWag": {
      "duration": 300,
      "rotationRange": [-15, 15]
    },
    "blink": {
      "duration": 100,
      "scaleYRange": [0, 1],
      "delayBetweenBlinks": 3000
    }
  },
  "levelIndicator": {
    "type": "dots",
    "dotSize": 8,
    "dotCount": 3,
    "backgroundColor": "theme.primary",
    "dotColor": "theme.primaryForeground",
    "inactiveDotColor": "theme.border",
    "borderRadius": 12,
    "padding": 4
  },
  "shadow": {
    "offset": { "x": 0, "y": 8 },
    "opacity": 0.12,
    "borderRadius": 4
  },
  "position": {
    "bottom": 120,
    "right": 40
  }
}
