{
  "component": "RoomBackground",
  "description": "Wall and floor background with ambient lighting effects",
  "dimensions": {
    "wallHeight": "75%",
    "floorHeight": "25%"
  },
  "gradients": {
    "ocean": {
      "wall": ["#E8F4F8", "#D1E8F0", "#C5E0E8"],
      "floor": ["#D4E8F0", "#C8DCE8", "#B8D0E0"],
      "ambient": "rgba(2, 132, 199, 0.15)"
    },
    "romance": {
      "wall": ["#FFF5F7", "#FCE8EC", "#F8DDE4"],
      "floor": ["#F8E8EC", "#F0D8E0", "#E8D0D8"],
      "ambient": "rgba(190, 24, 93, 0.12)"
    },
    "futuristic": {
      "wall": ["#0A1520", "#0D1A2A", "#081018"],
      "floor": ["#0D1A2A", "#0A1520", "#081218"],
      "ambient": "rgba(0, 229, 255, 0.1)"
    },
    "simplistic": {
      "wall": ["#F8F8F6", "#F0F0EC", "#F5F5F2"],
      "floor": ["#ECECE8", "#E4E4E0", "#E8E8E4"],
      "ambient": "rgba(64, 64, 64, 0.08)"
    },
    "nature": {
      "wall": ["#F2F6E8", "#E8EED8", "#F0F4DC"],
      "floor": ["#E8EED8", "#DCE8D0", "#E0E6D4"],
      "ambient": "rgba(63, 125, 32, 0.1)"
    }
  },
  "animations": {
    "ambientPulse": {
      "duration": 4000,
      "opacityRange": [0.3, 0.5]
    },
    "textureShift": {
      "duration": 6000,
      "opacityRange": [0.1, 0.2]
    }
  },
  "layers": [
    {
      "name": "Wall Gradient",
      "type": "linear-gradient",
      "position": "top",
      "height": "75%"
    },
    {
      "name": "Ambient Light",
      "type": "overlay",
      "opacity": "animated",
      "color": "theme-dependent"
    },
    {
      "name": "Wall Texture",
      "type": "overlay",
      "opacity": 0.02,
      "color": "rgba(0,0,0,0.02)"
    },
    {
      "name": "Floor Gradient",
      "type": "linear-gradient",
      "position": "bottom",
      "height": "25%"
    },
    {
      "name": "Floor Shadow",
      "type": "shadow",
      "position": "above floor",
      "height": 20,
      "opacity": 0.08
    }
  ]
}
